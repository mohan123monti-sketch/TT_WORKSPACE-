# Server
PORT=3000

# Security — change JWT_SECRET to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production

# OpenAI — leave blank to use Nexus AI mock mode (works without a key)
OPENAI_API_KEY=

# Database path
DB_PATH=./techturf.db

# App URL (used for CORS restriction)
APP_URL=http://localhost:3000
