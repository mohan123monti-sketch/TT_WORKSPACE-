# Server
PORT=3000

# Security — change JWT_SECRET to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES=8h

# OpenAI API key for Nexus AI features
OPENAI_API_KEY=

# Database path
DB_PATH=./techturf.db

# App URL (used for CORS restriction)
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:5000
